# Backend Environment Variables
# Copy this file to .env for local development
# In Render dashboard: Environment → Add Environment Variables

# MongoDB Atlas connection string
# Get from: cloud.mongodb.com → Connect → Drivers
MONGO_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/brotherhood?retryWrites=true&w=majority

# JWT secret — any long random string (e.g. run: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_here

# Razorpay API keys — get from razorpay.com → Settings → API Keys
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Your Vercel frontend URL (for CORS whitelist)
# e.g. https://brotherhood-xyz.vercel.app
FRONTEND_URL=https://your-brotherhood-app.vercel.app

# Email notifications (optional) — Gmail SMTP
# Use an App Password (not your main Gmail password)
# gmail.com → Google Account → Security → 2-Step Verification → App passwords
GMAIL_USER=youremail@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Owner email to receive new order alerts
OWNER_EMAIL=owner@example.com

# Server port (Render sets this automatically, don't change)
PORT=3000
